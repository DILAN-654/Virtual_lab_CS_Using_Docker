# Server
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed browser origins.
# Example: http://localhost:8000,http://127.0.0.1:8000
CORS_ORIGIN=http://localhost:8000,http://127.0.0.1:8000

# Database
MONGODB_URI=mongodb://localhost:27017/virtual-lab-workbench

# JWT
JWT_SECRET=dev_secret_change_me
JWT_EXPIRE=30d

# Docker (optional - leave empty for default socket)
DOCKER_HOST=
MONITORING_POLL_INTERVAL_MS=4000
MONITORING_CONTAINER_OVERLOAD_THRESHOLD=10
MONITORING_IDLE_MINUTES=20
AUTO_CLEANUP_IDLE_MINUTES=30

# AI
AI_PROVIDER=openai
AI_ENABLED=true
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini (optional fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
